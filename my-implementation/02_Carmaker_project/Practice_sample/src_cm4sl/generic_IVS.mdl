        <P Name="isEML">1</P>
        <P Name="script">function ax = lonctrl(Traj, Ego)
%#codegen
target=Traj(3); v=Ego(4); ax=0.6*(target-v);
if ax&gt;3; ax=3; elseif ax&lt;-4; ax=-4; end
end</P>
